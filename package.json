{
  "name": "vendorhub-api",
  "version": "1.0.0",
  "description": "VendorHub Backend REST API",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "build": "prisma generate && prisma db push && node src/seed.js",
    "db:push": "prisma db push",
    "db:seed": "node src/seed.js",
    "db:studio": "prisma studio",
    "setup": "npm install && npx prisma db push && node src/seed.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "prisma": "^5.22.0"
  }
}
