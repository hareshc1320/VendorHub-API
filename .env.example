# ─── DATABASE ───────────────────────────────────────────────
# SQLite — no external DB needed. Works out of the box.
DATABASE_URL="file:./vendorhub.db"

# ─── JWT ────────────────────────────────────────────────────
# Change this to a long random string before going live!
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="change-this-to-a-long-random-secret"

# ─── SERVER PORT ────────────────────────────────────────────
PORT=3001

# ─── CORS ───────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no spaces)
# Local:      CORS_ORIGIN="http://localhost:5173,http://localhost:5174"
# Production (replace with your actual Vercel URLs):
CORS_ORIGIN="https://your-admin.vercel.app,https://your-website.vercel.app"
